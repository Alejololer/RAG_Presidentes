# =============================================================================
# RAG Presidentes Ecuador - Configuracion
# Copiar a .env y editar: cp .env.example .env
# El setup script hace esto automaticamente la primera vez.
# =============================================================================

# Puerto del servicio (default 8010)
PUERTO=8010

# URL de Ollama (vive en el HOST, no dentro del contenedor).
# - Windows / macOS (Docker Desktop): host.docker.internal funciona.
# - Linux: el setup script configura USE_HOST_NETWORK=true automaticamente.
#   En ese caso OLLAMA_HOST=http://localhost:11434 funciona.
# - Si Ollama vive en otra PC de la red: usar su IP, ej. http://192.168.1.50:11434
OLLAMA_HOST=http://host.docker.internal:11434

# Modelo a usar (debe estar descargado en Ollama)
OLLAMA_MODEL=qwen2.5:7b

# Cuantos chunks recuperar por consulta (default 5)
RAG_TOP_K=5

# Origenes CORS permitidos (separados por coma, * = todos).
# En produccion: la URL del front Next.js, ej. https://opcion2049.example
CORS_ORIGINS=*

# Plataforma para build multi-arch (dejar vacio = auto-detectar).
# Valores posibles: linux/amd64, linux/arm64, linux/amd64,linux/arm64
BUILDPLATFORM=

# (Linux only) Modo de red del contenedor.
# Valores validos:
#   - "host"   : el contenedor usa la red del host (necesario en Linux porque
#                host.docker.internal no funciona en el bridge de Docker).
#                OLLAMA queda accesible en http://localhost:11434.
#   - "bridge" : red bridge por defecto (default en Windows/macOS con Docker
#                Desktop). OLLAMA queda accesible via host.docker.internal.
# El setup script configura esto automaticamente segun el OS.
# NO usar valores booleanos (true/false) — Docker compose los rechaza.
USE_HOST_NETWORK=bridge
